# Switched to the latest stable 2.11.2 release
FROM apache/airflow:2.11.2-python3.11 AS base

USER root

# 1. System-level dependencies for Weather Data (GRIB/NetCDF)
RUN apt-get update || (sleep 5 && apt-get update) && \
    apt-get install -y --no-install-recommends \
    dumb-init \
    git \
    libeccodes-dev \
    libeccodes0 \
    libmagic1 \
    build-essential \
    libpq-dev \
    curl \
    sudo \
    && apt-get autoremove -yqq --purge \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Allow the airflow user to use sudo for debugging
RUN echo "airflow ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# --- Permanent Environment Pathing ---
ENV IPYTHONDIR=/home/airflow/.ipython
ENV HOME=/home/airflow

USER airflow

# 2. Optimized Python Stack
RUN set -ex \
    && AIRFLOW_VERSION=$(airflow version) \
    && PYTHON_VERSION=$(python -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")') \
    && CONSTRAINT_URL="https://raw.githubusercontent.com/apache/airflow/constraints-${AIRFLOW_VERSION}/constraints-${PYTHON_VERSION}.txt" \
    && pip install --no-cache-dir \
        "apache-airflow==${AIRFLOW_VERSION}" \
        ecmwf-opendata \
        xarray \
        dask \
        cfgrib \
        netCDF4 \
        eccodes \
        boto3 \
        duckdb \
        pyarrow \
        deltalake \
        pandas \
        python-magic \
        apache-airflow-providers-amazon \
        snowflake-connector-python \
        psycopg2-binary \
        sqlalchemy \
        python-dotenv \
        docker \
        --constraint "${CONSTRAINT_URL}" \
    && pip install --no-cache-dir dbt-core dbt-duckdb dbt-postgres

# 2.5 Pre-install DuckDB extensions
RUN python3 -c "import duckdb; con = duckdb.connect(); con.execute('INSTALL httpfs; INSTALL aws; INSTALL delta;')"

# 3. Configure Jupyter/IPython Startup
USER root

RUN mkdir -p /home/airflow/.ipython/profile_default/startup/ && \
    chown -R 50000:0 /home/airflow/.ipython

# CRITICAL: Note the 'EOF' (with quotes) to prevent shell variable expansion
RUN cat <<'EOF' > /home/airflow/.ipython/profile_default/startup/00-duckdb-init.py
import duckdb
import os
from IPython import get_ipython

try:
    con = duckdb.connect(':memory:')
    # Use global duckdb module to configure the default session
    con.execute("LOAD httpfs; LOAD aws; LOAD delta;")

    # --- 1. MAIN CONNECTION: OCI (Global Scope) ---
    oci_key = os.environ.get('OCI_ACCESS_KEY') or os.environ.get('OCI_OBJECT_STORAGE_ACCESS_KEY')
    oci_secret = os.environ.get('OCI_SECRET_KEY') or os.environ.get('OCI_OBJECT_STORAGE_SECRET_KEY')
    oci_ns = os.environ.get('OCI_NAMESPACE') or os.environ.get('OCI_OBJECT_STORAGE_NAMESPACE')
    oci_reg = os.environ.get('OCI_REGION', 'us-ashburn-1')
    
    if oci_key and oci_secret and oci_ns:
        endpoint = f"{oci_ns}.compat.objectstorage.{oci_reg}.oraclecloud.com"
        
        con.execute(f"""
            CREATE OR REPLACE SECRET oci_main (
                TYPE S3, KEY_ID '{oci_key}', SECRET '{oci_secret}',
                REGION '{oci_reg}', ENDPOINT '{endpoint}',
                URL_STYLE 'path', USE_SSL 'true', SCOPE 's3://'
            );
        """)
        
        # Force session settings to prevent AWS metadata lookups (the 169.254 error)
        con.execute(f"SET s3_endpoint = '{endpoint}';")
        con.execute("SET s3_url_style = 'path';")
        con.execute(f"SET s3_region = '{oci_reg}';")
        # duckdb.execute(f"SET s3_endpoint = '{endpoint}';")
        # duckdb.execute("SET s3_url_style = 'path';")
        # duckdb.execute(f"SET s3_region = '{oci_reg}';")
        print('✅ DuckDB OCI Secret & Global Settings Initialized')

    # --- 2. OPTIONAL CONNECTION: AWS (Scoped) ---
    if os.environ.get('WORKBENCH_MODE') == 'true':
        aws_key = os.environ.get('AWS_ACCESS_KEY_ID')
        aws_secret = os.environ.get('AWS_SECRET_ACCESS_KEY')
        if aws_key and aws_secret:
            con.execute(f"""
                CREATE OR REPLACE SECRET aws_scoped (
                    TYPE S3, KEY_ID '{aws_key}', SECRET '{aws_secret}',
                    REGION '{os.environ.get('AWS_REGION', 'us-east-1')}',
                    SCOPE 's3://amzn-s3-ykg-storage'
                );
            """)
            print('✅ AWS Scoped connection enabled.')

    # 3. Tether to JupySQL
    ipy = get_ipython()
    if ipy:
        if 'sql' not in ipy.extension_manager.loaded: 
            ipy.run_line_magic('load_ext', 'sql')
        # Standard bridge to the global DuckDB session
        ipy.run_line_magic('sql', 'con') 
        ipy.run_line_magic('config', 'SqlMagic.autopandas = True')
        ipy.run_line_magic('config', 'SqlMagic.displaycon = False')
        print("✅ JupySQL connected to DuckDB")

except Exception as e:
    print(f'⚠️ Startup Error: {e}')
EOF

RUN chown 50000:0 /home/airflow/.ipython/profile_default/startup/00-duckdb-init.py
USER 50000

ENTRYPOINT ["/usr/bin/dumb-init", "--", "/entrypoint"]

# --- TARGET 1: jupyter-developer-env ---
FROM base AS jupyter-developer-env
ENV WORKBENCH_MODE=true

USER root
RUN mkdir -p /home/airflow/work && chown -R 50000:0 /home/airflow/work && chmod -R g+w /home/airflow/work 
USER 50000

RUN pip install --no-cache-dir \
    jupyterhub==5.4.4 jupyterlab jupysql oci boto3 \
    pydantic-settings jupyter-ai jupyter-ai-jupyternaut \
    jupyterlab-git langchain-openai openai

# Hub expects 'jupyterhub-singleuser'
CMD ["jupyterhub-singleuser", "--ip=0.0.0.0", "--port=8888", "--ServerApp.root_dir=/home/airflow/work"]

# --- TARGET 2: airflow-worker ---
FROM base AS airflow-base
CMD ["bash"]